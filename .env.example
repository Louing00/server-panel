NODE_ENV=development
PORT=3100
WEB_PORT=5173
APP_PORT=3100
COMPOSE_PROJECT_NAME=server-panel
POSTGRES_USER=panel
POSTGRES_PASSWORD=panel_password
POSTGRES_DB=panel
DATABASE_URL=postgresql://panel:panel_password@localhost:5432/panel
REDIS_URL=redis://localhost:6379
JWT_SECRET=please_change_this_to_a_long_random_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
APP_MASTER_KEY=replace_with_base64_32_byte_key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
SSH_CONNECT_TIMEOUT_MS=10000
SSH_IDLE_TIMEOUT_MS=1800000
MAX_UPLOAD_SIZE_MB=200
